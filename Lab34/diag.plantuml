@startuml
skinparam classAttributeIconSize 0

' ===== Интерфейс =====
interface Actionable {
    +act() : void
}

' ===== Абстрактный класс =====
abstract class Character {
    -name : String
    -energy : int
    +act() : void
    #spendEnergy(amount : int) : void
    +toString() : String
    +equals(o : Object) : boolean
    +hashCode() : int
}

Actionable <|.. Character

' ===== Персонажи =====
class Znayka {
    +proposeDualControl(rocket : Rocket) : void
}

class Fuksiya {
    +drawSketch() : Blueprint
}

class Seledochka {
    +drawSketch() : Blueprint
}

class Engineer {
    +createBlueprint(part : String) : Blueprint
}

Character <|-- Znayka
Character <|-- Fuksiya
Character <|-- Seledochka
Character <|-- Engineer

' ===== Ракета =====
class Rocket {
    -stages : List<RocketStage>
    -controlMode : ControlMode
    +addStage(stage : RocketStage) : void
    +enableDualControl() : void
    +switchMode(mode : ControlMode) : void
}

class RocketStage {
    -dualControl : boolean
    +setDualControl(value : boolean) : void
}

Rocket "1" *-- "1..*" RocketStage

' ===== Enum =====
enum ControlMode {
    GRAVITY
    ZERO_GRAVITY
}

Rocket --> ControlMode

' ===== Record =====
class Blueprint <<record>> {
    partName : String
    complexity : int
}

' ===== Завод =====
class Factory {
    +produce(blueprint : Blueprint) : void
}

Factory --> Blueprint

' ===== Лунит =====
class Lunit {
    -mass : double
    +getMass() : double
}

' ===== Исключения =====
class NoLunitException <<exception>> {
    +getMessage() : String
}

class EnergyException <<exception>>

@enduml
